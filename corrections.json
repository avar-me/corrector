    { "pattern": "ХI",  "replacement": "ХӀ" },
    { "pattern": "Хl",  "replacement": "ХӀ" },
    { "pattern": "к1",  "replacement": "кӏ" },
    { "pattern": "кI",  "replacement": "кӏ" },
    { "pattern": "кl",  "replacement": "кӏ" },
    { "pattern": "К1",  "replacement": "КӀ" },
    { "pattern": "КI",  "replacement": "КӀ" },
    { "pattern": "Кl",  "replacement": "КӀ" },
    { "pattern": "ц1",  "replacement": "цӏ" },
    { "pattern": "цI",  "replacement": "цӏ" },
    { "pattern": "цl",  "replacement": "цӏ" },
    { "pattern": "Ц1",  "replacement": "ЦӀ" },
    { "pattern": "ЦI",  "replacement": "ЦӀ" },
    { "pattern": "Цl",  "replacement": "ЦӀ" },
    { "pattern": "ч1",  "replacement": "чӏ" },
    { "pattern": "чI",  "replacement": "чӏ" },
    { "pattern": "чl",  "replacement": "чӏ" },
    { "pattern": "Ч1",  "replacement": "ЧӀ" },
    { "pattern": "ЧI",  "replacement": "ЧӀ" },
    { "pattern": "Чl",  "replacement": "ЧӀ" },
    { "pattern": "т1",  "replacement": "тӏ" },
    { "pattern": "тI",  "replacement": "тӏ" },
    { "pattern": "тl",  "replacement": "тӏ" },
